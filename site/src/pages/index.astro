---
import Base from "wicked-web/layouts/Base.astro";
import Topbar from "wicked-web/components/Topbar.astro";
import Footer from "wicked-web/components/Footer.astro";
import SameGarden from "wicked-web/components/SameGarden.astro";
import "../styles/global.css";
import Hero from "../components/react/Hero.tsx";
import Manifesto from "../components/react/Manifesto.tsx";
import SessionExplorer from "../components/react/SessionExplorer.tsx";
import GardenBench from "../components/react/GardenBench.tsx";

const favicon = `${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/{2,}/g, "/");
---

<Base
  title="wicked-garden — the curated toolkit for what coding agents can't do alone"
  description="Your coding-agent harness already plans, swarms, and ships. wicked-garden fills only the gaps a planner-executor can't: re-derive “done” from evidence (never asserted), see injected edges grep can't, rename across files as a graph operation, remember decisions across sessions, load the repo's own playbooks, and convene a real multi-model panel. Installs as one Claude Code plugin; the evidence gate compiles into any repo and runs with no wicked-garden present. Local-first, MIT, v12.27.0."
  bodyClass="has-grain"
  favicon={favicon}
>
  <Topbar pkg="wicked-garden" repo="https://github.com/mikeparcewski/wicked-garden" />
  <main>
    <!-- Hero renders <section id="top"> — snap target -->
    <Hero client:load />

    <!-- Manifesto — sentinel-driven scroll-pin, border-t scopes the section -->
    <div class="border-t border-line section-alt">
      <Manifesto client:visible />
    </div>

    <!-- Session explorer — hydrate on load (not :visible) so phones don't flash
         the SSR scroll-jacked stage before the mobile list swaps in -->
    <div class="border-t border-line">
      <SessionExplorer client:load />
    </div>

    <!-- Garden bench — snap target -->
    <section id="bench" class="border-t border-line section-alt">
      <GardenBench client:visible />
    </section>
  </main>
  <SameGarden current="wicked-garden" />
  <div id="footer-snap">
    <Footer repo="https://github.com/mikeparcewski/wicked-garden" />
  </div>
</Base>
