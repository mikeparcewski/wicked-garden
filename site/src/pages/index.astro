---
import Base from "wicked-web/layouts/Base.astro";
import Topbar from "wicked-web/components/Topbar.astro";
import Footer from "wicked-web/components/Footer.astro";
import "../styles/global.css";
import "../styles/wall.css";
import ToolWallHero from "../components/react/ToolWallHero.tsx";
import ToolWall from "../components/react/ToolWall.tsx";
import ProveBench from "../components/react/ProveBench.tsx";
import GardenBench from "../components/react/GardenBench.tsx";

const favicon = `${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/{2,}/g, "/");
---

<Base
  title="wicked-garden — the wall of tools your coding agent can't build alone"
  description="Your coding-agent harness already plans, swarms, and ships. wicked-garden is not a workflow — it's an inventory you load out from. Six of garden's own bench tools (prove · injected-edge search · patch · council · playbooks · compile-the-gate) plus six bundled wicked-* peers (vault · testing · brain · understanding · bus · interactive). Its one differentiator: done is re-derived from evidence, never asserted — the gate re-runs the verifier and fails closed rather than trust a claim. One command installs the set. Local-first, MIT, v12.27.0."
  bodyClass="has-grain"
  favicon={favicon}
>
  <Topbar pkg="wicked-garden" repo="https://github.com/mikeparcewski/wicked-garden" />
  <main>
    <!-- Hero — the wall, not a workflow (snap target via #top) -->
    <ToolWallHero client:load />

    <!-- The Tool Wall — the full loadout on pegs, grabbable -->
    <section id="wall" class="border-t border-line section-alt">
      <ToolWall client:visible />
    </section>

    <!-- The Prove Bench — the signature interactive evidence gate -->
    <section id="prove" class="border-t border-line">
      <ProveBench client:load />
    </section>

    <!-- The Bench — install (snap target via #bench) -->
    <section id="bench" class="border-t border-line section-alt">
      <GardenBench client:visible />
    </section>
  </main>
  <div id="footer-snap">
    <Footer repo="https://github.com/mikeparcewski/wicked-garden" />
  </div>
</Base>
