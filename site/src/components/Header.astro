---
import ThemeToggle from "./react/ThemeToggle.tsx";

const home = `${import.meta.env.BASE_URL}/`.replace(/\/{2,}/g, "/");
const gh = "https://github.com/mikeparcewski";
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line/70"
  style="background: color-mix(in oklab, var(--canvas) 72%, transparent); backdrop-filter: blur(14px) saturate(140%);"
>
  <div class="mx-auto flex h-16 max-w-[1240px] items-center justify-between gap-4 px-5 sm:px-8">
    <a href={home} class="group flex items-center gap-2.5" aria-label="wickedagile — home">
      <span
        class="grid h-7 w-7 place-items-center rounded-[9px] transition-transform duration-300 group-hover:rotate-[18deg]"
        aria-hidden
        style="background: var(--accent); box-shadow: 0 0 0 1px color-mix(in oklab, var(--accent) 55%, transparent), 0 2px 8px color-mix(in oklab, var(--accent) 28%, transparent);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#232324" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
          <path d="M3 5l3.5 14L12 8l5.5 11L21 5"/>
        </svg>
      </span>
      <span class="font-display text-[1.22rem] font-extrabold tracking-tight"
        >wicked<span style="color: var(--accent)">agile</span></span
      >
      <span class="kicker hidden sm:inline" style="letter-spacing:0.22em">/ wicked-garden</span>
    </a>

    <div class="flex items-center gap-2">
      <a
        href={gh}
        target="_blank"
        rel="noreferrer"
        class="hidden h-10 items-center gap-2 rounded-full border border-line px-4 font-mono text-[0.74rem] uppercase tracking-[0.14em] text-ink transition-colors hover:border-accent hover:text-accent sm:flex"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden>
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.34c-2.23.49-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.8.06 1.23.83 1.23.83.72 1.23 1.87.87 2.33.67.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
        </svg>
        GitHub
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
