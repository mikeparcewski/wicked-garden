---
import "@fontsource-variable/archivo/wdth.css";
import "@fontsource-variable/hanken-grotesk";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "wickedagile / wicked garden — the local-first, no-black-box kit for AI-native development",
  description = "The open-source, local-first toolkit for AI-native engineers. Memory, evidence, and an SDLC that re-derives “done” instead of trusting a green checkmark.",
} = Astro.props;

const withBase = (p: string) => `${import.meta.env.BASE_URL}/${p}`.replace(/\/{2,}/g, "/");
const favicon = withBase("favicon.svg");
const ogImage = withBase("og.png");
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const ogAbsolute = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#232324" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#224a60" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogAbsolute} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbsolute} />

    <link rel="preconnect" href="https://github.com" />

    {/* Set theme before paint. Shared with the wicked-web Topbar toggle via
        data-theme + localStorage 'wa-theme' (garden defaults to its night mode). */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("wa-theme") || "dark";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="has-grain">
    <slot />
  </body>
</html>
