        "mode": "parallel",
        "fallback": "senior-engineer"
      }
    },
    "code-quality": {
      "minimal": {
        "reviewers": [],
        "mode": "self-check",
        "fallback": "senior-engineer"
      },
      "standard": {
        "reviewers": ["senior-engineer"],
        "mode": "sequential",
        "fallback": "senior-engineer"
