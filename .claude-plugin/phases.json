{
  "schema_version": "1.2",
  "phases": {
    "ideate": {
      "name": "ideate",
      "description": "Brainstorm and explore solution space",
      "triggers": ["ambiguity", "ux", "strategy"],
      "complexity_range": [3, 7],
      "required_deliverables": [
        {"file": "brainstorm-summary.md", "min_bytes": 100, "frontmatter": []}
      ],
      "optional_deliverables": [],
      "specialists": ["jam"],
      "required_specialists": [],
      "fallback_agent": "facilitator",
      "is_skippable": true,
      "depends_on": [],
      "confidence_threshold": 0.9,
      "gate_type": "generic",
      "checkpoint": false,
      "gate_required": false,
      "min_gate_score": null,
      "min_test_coverage": null,
      "conditions_manifest_required": false,
      "phase_executor_may_delegate": false,
      "valid_skip_reasons": [
        "complexity_below_threshold",
        "user_explicit_request",
        "out_of_scope"
      ]
    },
    "clarify": {
      "name": "clarify",
      "description": "Define outcome, complexity, and acceptance criteria",
      "triggers": ["*"],
      "complexity_range": [0, 7],
      "required_deliverables": [
        {"file": "objective.md", "min_bytes": 100, "frontmatter": []},
        {"file": "complexity.md", "min_bytes": 50, "frontmatter": []},
        {"file": "acceptance-criteria.md", "min_bytes": 100, "frontmatter": ["case_count"]}
      ],
      "optional_deliverables": ["stakeholders.md"],
      "specialists": ["product", "jam", "qe"],
      "required_specialists": ["product"],
      "fallback_agent": "facilitator",
      "is_skippable": false,
      "depends_on": [],
      "confidence_threshold": 0.85,
      "gate_type": "value",
      "checkpoint": true,
      "gate_required": true,
      "min_gate_score": 0.6,
      "min_test_coverage": null,
      "conditions_manifest_required": true,
      "phase_executor_may_delegate": false
    },
    "design": {
      "name": "design",
      "description": "Architecture, UX, and implementation strategy",
      "triggers": ["architecture", "complexity", "ux", "data"],
      "complexity_range": [3, 7],
      "required_deliverables": [
        {"file": "architecture.md", "min_bytes": 200, "frontmatter": []}
      ],
      "optional_deliverables": ["task-breakdown.md", "adrs/"],
      "specialists": ["engineering", "agentic", "product", "qe"],
      "required_specialists": ["engineering"],
      "fallback_agent": "researcher",
      "is_skippable": true,
      "depends_on": ["clarify"],
      "confidence_threshold": 0.8,
      "gate_type": "strategy",
      "checkpoint": true,
      "gate_required": true,
      "min_gate_score": 0.7,
      "min_test_coverage": null,
      "conditions_manifest_required": true,
      "consensus_threshold": 5,
      "consensus_proposers": ["engineering", "devsecops", "product"],
      "strong_dissent_blocks": true,
      "phase_executor_may_delegate": false,
      "valid_skip_reasons": [
        "complexity_below_threshold",
        "user_explicit_request",
        "ci_equivalent_exists",
        "out_of_scope"
      ]
    },
    "test-strategy": {
      "name": "test-strategy",
      "description": "Test planning, scenario generation, functional TDD setup",
      "triggers": ["*"],
      "complexity_range": [2, 7],
      "required_deliverables": [
        {"file": "test-strategy.md", "min_bytes": 200, "frontmatter": ["case_count"]}
      ],
      "optional_deliverables": ["test-scenarios.md"],
      "specialists": ["qe"],
      "required_specialists": ["qe"],
      "fallback_agent": "reviewer",
      "is_skippable": true,
      "depends_on": ["clarify"],
      "confidence_threshold": 0.8,
      "gate_type": "strategy",
      "checkpoint": false,
      "gate_required": true,
      "min_gate_score": 0.6,
      "min_test_coverage": null,
      "conditions_manifest_required": false,
      "skip_complexity_threshold": 3,
      "phase_executor_may_delegate": false,
      "valid_skip_reasons": [
        "complexity_below_threshold",
        "user_explicit_request",
        "ci_equivalent_exists"
      ]
    },
    "challenge": {
      "name": "challenge",
      "description": "Persistent contrarian review (Issue #442). The contrarian specialist produces phases/design/challenge-artifacts.md — a steelmanned opposing view, enumerated challenges with distinct themes, convergence-collapse self-check, and resolution for each challenge. Blocks build when complexity >= 4 and the artifact has not cleared the challenge-resolution gate.",
      "triggers": ["complexity", "architecture", "novelty", "reversibility"],
      "complexity_range": [4, 7],
      "required_deliverables": [
        {"file": "challenge-artifacts.md", "min_bytes": 300, "frontmatter": []}
      ],
      "optional_deliverables": ["steelman-notes.md"],
      "specialists": ["contrarian", "jam"],
      "required_specialists": ["contrarian"],
      "fallback_agent": "reviewer",
      "is_skippable": true,
      "depends_on": ["design"],
      "confidence_threshold": 0.75,
      "gate_type": "strategy",
      "checkpoint": false,
      "gate_required": true,
      "min_gate_score": 0.7,
      "min_test_coverage": null,
      "conditions_manifest_required": true,
      "skip_complexity_threshold": 4,
      "phase_executor_may_delegate": false,
      "valid_skip_reasons": [
        "complexity_below_threshold",
        "user_explicit_request",
        "out_of_scope"
      ]
    },
    "build": {
      "name": "build",
      "description": "Implementation with task tracking",
      "triggers": ["*"],
      "complexity_range": [0, 7],
      "required_deliverables": [],
      "optional_deliverables": [],
      "specialists": ["engineering", "platform", "data"],
      "required_specialists": ["engineering"],
      "fallback_agent": "implementer",
      "is_skippable": false,
      "depends_on": ["clarify", "design", "challenge"],
      "confidence_threshold": 0.7,
      "gate_type": "execution",
      "checkpoint": true,
      "gate_required": true,
      "min_gate_score": 0.7,
      "min_test_coverage": null,
      "conditions_manifest_required": false,
      "consensus_threshold": 5,
      "consensus_proposers": ["engineering", "quality-engineering", "devsecops"],
      "strong_dissent_blocks": true,
      "phase_executor_may_delegate": true
    },
    "test": {
      "name": "test",
      "description": "Product-level test execution: Playwright/Cypress E2E first, then live endpoint verification, then scenario validation. Unit suites run as regression baseline, not as primary verification.",
      "triggers": ["*"],
      "complexity_range": [2, 7],
      "required_deliverables": [
        {"file": "test-results.md", "min_bytes": 200, "frontmatter": ["pass_count", "fail_count"]},
        {"file": "evidence/report.md", "min_bytes": 100, "frontmatter": []}
      ],
      "optional_deliverables": ["coverage-report.md"],
      "specialists": ["qe"],
      "required_specialists": ["qe"],
      "fallback_agent": "reviewer",
      "is_skippable": false,
      "depends_on": ["build", "test-strategy"],
      "confidence_threshold": 0.75,
      "gate_type": "execution",
      "checkpoint": false,
      "gate_required": true,
      "min_gate_score": 0.8,
      "min_test_coverage": 0.80,
      "conditions_manifest_required": false,
      "phase_executor_may_delegate": true,
      "valid_skip_reasons": [
        "user_explicit_request",
        "ci_equivalent_exists"
      ]
    },
    "review": {
      "name": "review",
      "description": "Final review with evidence package evaluation: screenshots, execution traces, spec comparison. Sign-off and delivery readiness.",
      "triggers": ["*"],
      "complexity_range": [0, 7],
      "required_deliverables": [
        {"file": "review-findings.md", "min_bytes": 200, "frontmatter": ["verdict"]}
      ],
      "optional_deliverables": ["evidence-review.md"],
      "specialists": ["engineering", "qe", "product"],
      "required_specialists": ["engineering", "qe"],
      "fallback_agent": "reviewer",
      "is_skippable": false,
      "depends_on": ["build", "test"],
      "confidence_threshold": 0.7,
      "gate_type": "execution",
      "checkpoint": false,
      "gate_required": true,
      "min_gate_score": 0.7,
      "min_test_coverage": 0.80,
      "conditions_manifest_required": true,
      "consensus_threshold": 5,
      "consensus_proposers": ["quality-engineering", "product", "engineering"],
      "strong_dissent_blocks": true,
      "phase_executor_may_delegate": false
    },
    "operate": {
      "name": "operate",
      "description": "Post-delivery monitoring, incident tracking, and feedback collection. Captures operational signals and feeds them back into future planning.",
      "triggers": ["infrastructure", "security", "performance"],
      "complexity_range": [3, 7],
      "required_deliverables": [
        {"file": "operational-checklist.md", "min_bytes": 100, "frontmatter": []}
      ],
      "optional_deliverables": ["feedback-summary.md", "incident-log.md"],
      "specialists": ["platform", "qe"],
      "required_specialists": [],
      "fallback_agent": "reviewer",
      "is_skippable": true,
      "depends_on": ["review"],
      "confidence_threshold": 0.7,
      "gate_type": "feedback",
      "checkpoint": false,
      "gate_required": false,
      "min_gate_score": 0.6,
      "min_test_coverage": null,
      "conditions_manifest_required": false,
      "skip_complexity_threshold": 3,
      "phase_executor_may_delegate": false,
      "valid_skip_reasons": [
        "complexity_below_threshold",
        "user_explicit_request",
        "no_production_deployment",
        "internal_tooling"
      ]
    }
  }
}
